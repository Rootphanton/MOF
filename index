let activeCategory = null;
let activeLevel = 'all';
let searchQuery = '';

// ─── BUILD SIDEBAR ───
function buildSidebar() {
  const cats = {};
  POSITIONS.forEach((p, i) => {
    const cat = p.categoria || 'Otras Unidades';
    if (!cats[cat]) cats[cat] = { positions: [], icon: p.icono, color: p.color };
    cats[cat].positions.push({ ...p, _idx: i });
  });

  const nav = document.getElementById('sidebarNav');
  nav.innerHTML = '';

  // All link
  const allItem = document.createElement('div');
  allItem.className = 'cat-section';
  allItem.innerHTML = `<div class="cat-label active" id="cat-all" onclick="filterCategory(null)">
    🏛️ Todos los Cargos <span class="cat-count">${POSITIONS.length}</span>
  </div>`;
  nav.appendChild(allItem);

  Object.entries(cats).sort((a,b) => a[0].localeCompare(b[0])).forEach(([cat, data]) => {
    const section = document.createElement('div');
    section.className = 'cat-section';
    const catId = 'cat-' + cat.replace(/[^a-zA-Z0-9]/g, '_');
    section.innerHTML = `<div class="cat-label" id="${catId}" onclick="filterCategory('${cat.replace(/'/g,"\'")}')">
      ${data.icon} ${cat} <span class="cat-count">${data.positions.length}</span>
    </div>` +
    data.positions.map(p => `
      <div class="nav-item" onclick="openPosition(${p._idx})" data-cat="${cat}">
        <span class="nav-dot" style="background:${data.color}"></span>
        ${p.titulo}
      </div>`).join('');
    nav.appendChild(section);
  });
}

// ─── RENDER CARDS ───
function renderCards() {
  const area = document.getElementById('cardsArea');
  let filtered = POSITIONS.map((p, i) => ({ ...p, _idx: i }));

  if (searchQuery) {
    const q = searchQuery.toLowerCase();
    filtered = filtered.filter(p =>
      p.titulo.toLowerCase().includes(q) ||
      (p.OBJETIVO||'').toLowerCase().includes(q) ||
      (p.FUNCIONES||'').toLowerCase().includes(q) ||
      (p.categoria||'').toLowerCase().includes(q) ||
      (p.DEPENDENCIA||'').toLowerCase().includes(q)
    );
  }

  if (activeCategory) {
    filtered = filtered.filter(p => p.categoria === activeCategory);
  }

  if (activeLevel !== 'all') {
    filtered = filtered.filter(p => {
      const nivel = (p['NIVEL JERARQUICO'] || p['NIVEL JERÁRQUICO'] || '').toUpperCase();
      return nivel.includes(activeLevel);
    });
  }

  document.getElementById('visibleCount').innerHTML = `${filtered.length} <span>visibles</span>`;

  if (!filtered.length) {
    area.innerHTML = `<div class="empty-state"><div class="emoji">🔍</div><h3>Sin resultados</h3><p>Prueba con otro término o categoría.</p></div>`;
    return;
  }

  // Group by category
  const byCategory = {};
  filtered.forEach(p => {
    const cat = p.categoria || 'Otras';
    if (!byCategory[cat]) byCategory[cat] = [];
    byCategory[cat].push(p);
  });

  let html = '';
  Object.entries(byCategory).sort((a,b) => a[0].localeCompare(b[0])).forEach(([cat, positions]) => {
    const icon = positions[0].icono;
    const color = positions[0].color;
    html += `<div class="section-title">
      <span style="font-size:1.3rem">${icon}</span>
      ${cat}
      <span class="section-count">${positions.length} cargo${positions.length>1?'s':''}</span>
    </div>
    <div class="cards-grid">`;

    positions.forEach(p => {
      const nivel = p['NIVEL JERARQUICO'] || p['NIVEL JERÁRQUICO'] || '';
      const dep = p['DEPENDENCIA'] || '';
      const obj = p['OBJETIVO'] || '';
      const topColor = color;
      html += `<div class="card" onclick="openPosition(${p._idx})">
        <div class="card-top" style="background:${topColor}"></div>
        <div class="card-body">
          <div class="card-icon">${p.icono}</div>
          <div class="card-title">${p.titulo}</div>
          <div class="card-meta">
            ${nivel ? `<span class="meta-tag">${nivel.split(' ').slice(0,2).join(' ')}</span>` : ''}
          </div>
          ${dep ? `<div class="card-dep">Depende de: <strong>${dep.split('\n')[0]}</strong></div>` : ''}
          ${obj ? `<div class="card-obj">${obj}</div>` : ''}
        </div>
        <div class="card-footer">
          <span class="card-btn">Ver TDR completo →</span>
          ${nivel ? `<span class="card-nivel">${nivel.split(' ')[0]}</span>` : ''}
        </div>
      </div>`;
    });

    html += '</div>';
  });

  area.innerHTML = html;
}

// ─── FILTER FUNCTIONS ───
function filterCategory(cat) {
  activeCategory = cat;
  searchQuery = '';
  document.getElementById('searchInput').value = '';
  document.getElementById('mainTitle').textContent = cat || 'Todos los Cargos';
  
  // Update sidebar active states
  document.querySelectorAll('.cat-label').forEach(el => el.classList.remove('active'));
  const targetId = cat ? 'cat-' + cat.replace(/[^a-zA-Z0-9]/g, '_') : 'cat-all';
  const target = document.getElementById(targetId);
  if (target) target.classList.add('active');
  
  renderCards();
}

function filterLevel(level) {
  activeLevel = level;
  document.querySelectorAll('.filter-tab').forEach(el => el.classList.remove('active'));
  event.target.classList.add('active');
  renderCards();
}

// ─── SEARCH ───
document.getElementById('searchInput').addEventListener('input', function() {
  searchQuery = this.value.trim();
  activeCategory = null;
  document.querySelectorAll('.cat-label').forEach(el => el.classList.remove('active'));
  document.getElementById('cat-all').classList.add('active');
  document.getElementById('mainTitle').textContent = searchQuery ? `Búsqueda: "${searchQuery}"` : 'Todos los Cargos';
  renderCards();
});

// ─── MODAL ───
function openPosition(idx) {
  const p = POSITIONS[idx];
  const color = p.color || '#0d2b5e';

  // Badge
  document.getElementById('modalCatBadge').style.background = color;
  document.getElementById('modalCatBadge').innerHTML = `${p.icono} ${p.categoria}`;

  // Title
  document.getElementById('modalTitle').textContent = p.titulo;

  // Meta chips
  const nivel = p['NIVEL JERARQUICO'] || p['NIVEL JERÁRQUICO'] || '';
  const dep = p['DEPENDENCIA'] || '';
  const sup = p['EJERCE SUPERVISION'] || p['EJERCE SUPERVISIÓN'] || '';
  let meta = '';
  if (nivel) meta += `<div class="modal-meta-chip"><span class="label">Nivel:</span>${nivel}</div>`;
  if (dep) meta += `<div class="modal-meta-chip"><span class="label">Depende de:</span>${dep.split('\n')[0]}</div>`;
  if (sup && sup !== 'NINGUNA' && sup !== 'ninguna' && sup.trim()) meta += `<div class="modal-meta-chip"><span class="label">Supervisa:</span>${sup.split('\n')[0]}</div>`;
  document.getElementById('modalMeta').innerHTML = meta;

  // Tab 0 - Objetivo
  const obj = p['OBJETIVO'] || 'Sin información';
  document.getElementById('tabPanel0').innerHTML = `
    <div class="info-section">
      <div class="info-section-title"><span class="icon">🎯</span> Objetivo del Cargo</div>
      <div class="info-content highlight">${obj}</div>
    </div>
    <div style="background:linear-gradient(135deg,#0d1828,#111e30);border-radius:12px;padding:16px;margin-top:16px">
      <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-light);margin-bottom:8px">📍 Información del Puesto</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;font-size:0.84rem;color:var(--text)">
        <div><strong>Dependencia:</strong><br>${dep || '—'}</div>
        <div><strong>Nivel Jerárquico:</strong><br>${nivel || '—'}</div>
        <div><strong>Ejerce supervisión sobre:</strong><br>${sup || 'Ninguna'}</div>
        <div><strong>Área:</strong><br>${p.categoria || '—'}</div>
      </div>
    </div>`;

  // Tab 1 - Funciones
  const funcText = p['FUNCIONES'] || '';
  const funcLines = funcText.split('\n').filter(l => l.trim()).map(l => l.trim());
  let funcHtml = '';
  if (funcLines.length > 1) {
    funcHtml = '<ul class="func-list">' + funcLines.map((l, i) => `<li data-n="${i+1}">${l}</li>`).join('') + '</ul>';
  } else if (funcText) {
    funcHtml = `<div class="info-content">${funcText}</div>`;
  } else {
    funcHtml = '<p style="color:#999;font-style:italic">Sin funciones registradas</p>';
  }
  document.getElementById('tabPanel1').innerHTML = `
    <div class="info-section">
      <div class="info-section-title"><span class="icon">⚙️</span> Funciones Específicas del Cargo</div>
      ${funcHtml}
    </div>`;

  // Tab 2 - Requisitos
  const reqText = p['REQUISITOS ESENCIALES'] || '';
  const reqLines = reqText.split('\n').filter(l => l.trim() && !l.includes('requisitos esenciales son'));
  
  // Parse sections
  let formacion = [], experiencia = [], conocimientos = [], habilidades = [], otros = [];
  let currentSection = otros;
  reqLines.forEach(l => {
    const lu = l.toUpperCase();
    if (lu.includes('FORMACI') || lu.includes('TÍTULO') || lu.includes('TITULO') || lu.includes('LICENCIATURA') || lu.includes('BACHILLER')) {
      currentSection = formacion;
    } else if (lu.includes('EXPERIENCIA')) {
      currentSection = experiencia;
    } else if (lu.includes('CONOCIMIENTO')) {
      currentSection = conocimientos;
    } else if (lu.includes('CUALIDAD') || lu.includes('HABILIDAD')) {
      currentSection = habilidades;
    }
    if (l.trim()) currentSection.push(l.replace(/^[\d]+\.\s*/, '').replace(/^[a-z]\)\s*/i, '').trim());
  });

  const makeReqCard = (title, icon, items, colorClass='') => {
    if (!items.filter(i => i).length) return '';
    return `<div class="req-card ${colorClass}">
      <h4>${icon} ${title}</h4>
      <ul>${items.filter(i=>i).map(i => `<li>${i}</li>`).join('')}</ul>
    </div>`;
  };

  const reqCardHtml = [
    makeReqCard('Formación Académica', '🎓', formacion),
    makeReqCard('Experiencia', '💼', experiencia),
    makeReqCard('Conocimientos', '📚', conocimientos),
    makeReqCard('Cualidades y Habilidades', '✨', habilidades),
    makeReqCard('Otros Requisitos', '📌', otros),
  ].filter(Boolean).join('');

  document.getElementById('tabPanel2').innerHTML = `
    <div class="info-section">
      <div class="info-section-title"><span class="icon">📋</span> Requisitos Esenciales del Cargo</div>
      ${reqCardHtml ? `<div class="req-grid">${reqCardHtml}</div>` : `<div class="info-content">${reqText || 'Sin información'}</div>`}
    </div>`;

  // Tab 3 - Relaciones
  const relInt = p['RELACIONES INTERNAS'] || '';
  const relExt = p['RELACIONES EXTERNAS'] || '';
  document.getElementById('tabPanel3').innerHTML = `
    <div class="info-section">
      <div class="info-section-title"><span class="icon">🔗</span> Relaciones Institucionales</div>
      <div class="rel-grid">
        <div class="rel-box">
          <h4>🏢 Relaciones Internas</h4>
          <p>${relInt || '—'}</p>
        </div>
        <div class="rel-box ext">
          <h4>🌐 Relaciones Externas</h4>
          <p>${relExt || '—'}</p>
        </div>
      </div>
    </div>`;

  // Tab 4 - Sanciones
  document.getElementById('tabPanel4').innerHTML = `
    <div class="info-section">
      <div class="info-section-title"><span class="icon">⚠️</span> Marco de Responsabilidad Legal</div>
      <div class="alert-box">
        <strong>⚖️ Responsabilidad del Servidor Público (Art. 28, Ley 1178 SAFCO)</strong><br><br>
        Todo Servidor Público responderá de los resultados emergentes del desempeño de sus funciones, deberes y atribuciones asignadas. La responsabilidad puede ser:
        <ul style="margin-top:10px;padding-left:20px;line-height:1.8">
          <li><strong>Administrativa:</strong> Por incumplimiento de normas y procedimientos internos</li>
          <li><strong>Civil:</strong> Por daños económicos causados a la entidad</li>
          <li><strong>Penal:</strong> Por actos que constituyan delito en ejercicio de sus funciones</li>
        </ul>
        <br>Se presume la licitud de las operaciones realizadas por todo servidor, mientras no se demuestre lo contrario.
      </div>
    </div>
    <div style="margin-top:16px;background:#0d1e18;border:1px solid #1a3028;border-radius:12px;padding:14px">
      <div style="font-size:0.78rem;font-weight:700;color:var(--success);margin-bottom:8px">✅ Principios del Servidor Público</div>
      <div style="display:flex;flex-wrap:wrap;gap:8px;font-size:0.8rem">
        ${['Eficacia','Economía','Eficiencia','Transparencia','Licitud','Responsabilidad','Imparcialidad','Ética'].map(v=>`<span style="background:#0d1e18;border:1px solid #1a3028;border-radius:20px;padding:4px 12px;color:#6ecfa8">${v}</span>`).join('')}
      </div>
    </div>`;

  // Reset to first tab
  document.querySelectorAll('.modal-tab').forEach((t,i) => t.classList.toggle('active', i===0));
  document.querySelectorAll('.tab-panel').forEach((p,i) => p.classList.toggle('active', i===0));

  document.getElementById('modalOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal(e) {
  if (e.target === document.getElementById('modalOverlay')) {
    document.getElementById('modalOverlay').classList.remove('open');
    document.body.style.overflow = '';
  }
}

function switchTab(idx, btn) {
  document.querySelectorAll('.modal-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('tabPanel'+idx).classList.add('active');
}

// ─── KEYBOARD ───
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    document.getElementById('modalOverlay').classList.remove('open');
    document.body.style.overflow = '';
  }
});

// ─── INIT ───
buildSidebar();
renderCards();
</script>

