<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MOF 2025 — G.A.M. Huanuni | Comisión Técnica Entrante</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Source+Sans+3:wght@300;400;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --primary: #3a7bd5;
    --primary-mid: #5a9ae0;
    --accent: #f0b429;
    --accent-light: #ffd24a;
    --bg: #0e1420;
    --white: #161f30;
    --text: #dce6f5;
    --text-light: #7a93b8;
    --border: #243050;
    --success: #2ecc71;
    --card-shadow: 0 4px 20px rgba(0,0,0,0.4);
    --sidebar-w: 280px;
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    font-family: 'Source Sans 3', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  /* ─── TOPBAR ─── */
  .topbar {
    background: linear-gradient(135deg, #0a1a3a 0%, #0d2050 60%, #152860 100%);
    color: white;
    padding: 0;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 20px rgba(0,0,0,0.4);
  }
  .topbar-inner {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 14px 28px;
  }
  .topbar-logo {
    width: 52px; height: 52px;
    background: var(--accent);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 26px;
    flex-shrink: 0;
    box-shadow: 0 2px 10px rgba(201,146,42,0.5);
  }
  .topbar-titles { flex: 1; }
  .topbar-titles h1 {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 900;
    line-height: 1.2;
    letter-spacing: 0.5px;
  }
  .topbar-titles p {
    font-size: 0.78rem;
    opacity: 0.75;
    font-weight: 300;
    margin-top: 2px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .topbar-badge {
    background: var(--accent);
    color: white;
    padding: 6px 16px;
    border-radius: 30px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    white-space: nowrap;
    box-shadow: 0 2px 8px rgba(201,146,42,0.4);
  }
  .topbar-search {
    display: flex;
    align-items: center;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 30px;
    padding: 6px 16px;
    gap: 8px;
    backdrop-filter: blur(4px);
    min-width: 240px;
  }
  .topbar-search input {
    background: none;
    border: none;
    outline: none;
    color: white;
    font-family: inherit;
    font-size: 0.9rem;
    width: 100%;
  }
  .topbar-search input::placeholder { color: rgba(255,255,255,0.5); }
  .topbar-search span { color: rgba(255,255,255,0.5); font-size: 16px; }

  /* ─── LAYOUT ─── */
  .layout {
    display: flex;
    min-height: calc(100vh - 82px);
  }

  /* ─── SIDEBAR ─── */
  .sidebar {
    width: var(--sidebar-w);
    background: var(--white);
    border-right: 1px solid var(--border);
    position: sticky;
    top: 82px;
    height: calc(100vh - 82px);
    overflow-y: auto;
    flex-shrink: 0;
  }
  .sidebar::-webkit-scrollbar { width: 4px; }
  .sidebar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .sidebar-header {
    background: var(--primary);
    color: white;
    padding: 16px 20px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .sidebar-stats {
    padding: 12px 20px;
    background: #0d1828;
    border-bottom: 1px solid var(--border);
    display: flex;
    gap: 12px;
  }
  .stat-pill {
    background: var(--primary);
    color: white;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.72rem;
    font-weight: 600;
  }
  .stat-pill span { opacity: 0.7; font-weight: 400; margin-left: 4px; }

  .cat-section { padding: 8px 0; }
  .cat-label {
    padding: 10px 20px 6px;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-light);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: background 0.2s;
  }
  .cat-label:hover { background: rgba(201,146,42,0.08); }
  .cat-label.active { color: var(--accent); }
  .cat-count {
    background: var(--border);
    color: var(--text-light);
    border-radius: 10px;
    padding: 2px 6px;
    font-size: 0.65rem;
    margin-left: auto;
  }
  .cat-label.active .cat-count { background: var(--accent); color: white; }
  
  .nav-item {
    padding: 8px 20px 8px 32px;
    font-size: 0.82rem;
    color: var(--text-light);
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: flex-start;
    gap: 8px;
    line-height: 1.3;
    border-left: 3px solid transparent;
  }
  .nav-item:hover {
    background: rgba(13,43,94,0.05);
    color: var(--primary);
    border-left-color: var(--primary);
  }
  .nav-item.active {
    background: rgba(201,146,42,0.1);
    color: var(--accent);
    border-left-color: var(--accent);
    font-weight: 600;
  }
  .nav-dot { width: 6px; height: 6px; border-radius: 50%; margin-top: 5px; flex-shrink: 0; }

  /* ─── MAIN CONTENT ─── */
  .main {
    flex: 1;
    min-width: 0;
    padding: 0;
  }

  .main-header {
    padding: 24px 32px 20px;
    background: var(--white);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .main-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    color: var(--primary);
    flex: 1;
  }
  .filter-tabs {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .filter-tab {
    padding: 6px 14px;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: var(--white);
    color: var(--text-light);
    font-size: 0.78rem;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
  }
  .filter-tab:hover { border-color: var(--primary); color: var(--primary); }
  .filter-tab.active { background: var(--primary); border-color: var(--primary); color: white; }

  .view-hint {
    background: linear-gradient(135deg, #1a2535 0%, #1e2a3a 100%);
    border: 1px solid #3a4a2a;
    border-left: 4px solid var(--accent);
    padding: 12px 32px;
    font-size: 0.85rem;
    color: #c8b870;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  /* ─── CARD GRID ─── */
  .cards-area { padding: 24px 32px 32px; }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    color: var(--primary);
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--accent-light);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-count {
    background: var(--accent);
    color: white;
    border-radius: 12px;
    padding: 2px 10px;
    font-size: 0.75rem;
    font-family: 'Source Sans 3', sans-serif;
    font-weight: 600;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
    margin-bottom: 36px;
  }

  .card {
    background: var(--white);
    border-radius: 14px;
    box-shadow: var(--card-shadow);
    cursor: pointer;
    transition: all 0.25s;
    overflow: hidden;
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(13,43,94,0.18);
    border-color: rgba(201,146,42,0.4);
  }
  .card-top {
    height: 8px;
  }
  .card-body { padding: 18px 20px 16px; flex: 1; }
  .card-icon { font-size: 2rem; margin-bottom: 8px; }
  .card-title {
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--primary);
    line-height: 1.3;
    margin-bottom: 10px;
    font-family: 'Playfair Display', serif;
  }
  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 10px;
  }
  .meta-tag {
    background: #1a2840;
    color: var(--primary-mid);
    border-radius: 8px;
    padding: 3px 10px;
    font-size: 0.72rem;
    font-weight: 600;
  }
  .card-dep {
    font-size: 0.78rem;
    color: var(--text-light);
    margin-bottom: 10px;
    line-height: 1.4;
  }
  .card-dep strong { color: var(--text); }
  .card-obj {
    font-size: 0.78rem;
    color: var(--text-light);
    line-height: 1.5;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
  }
  .card-footer {
    padding: 10px 20px;
    background: #0d1828;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .card-btn {
    font-size: 0.75rem;
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.5px;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .card-nivel {
    font-size: 0.68rem;
    background: var(--primary);
    color: white;
    padding: 3px 8px;
    border-radius: 6px;
    font-weight: 600;
  }

  /* ─── MODAL ─── */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(10,20,50,0.75);
    z-index: 1000;
    backdrop-filter: blur(4px);
    animation: fadeIn 0.2s ease;
  }
  .modal-overlay.open { display: flex; align-items: center; justify-content: center; padding: 20px; }
  @keyframes fadeIn { from { opacity:0 } to { opacity:1 } }

  .modal {
    background: var(--white);
    border-radius: 20px;
    max-width: 820px;
    width: 100%;
    max-height: 90vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 30px 80px rgba(0,0,0,0.5);
    animation: slideUp 0.25s ease;
  }
  @keyframes slideUp { from { transform:translateY(30px); opacity:0 } to { transform:none; opacity:1 } }

  .modal-header {
    padding: 24px 28px;
    display: flex;
    align-items: flex-start;
    gap: 16px;
    border-bottom: 1px solid var(--border);
  }
  .modal-header-left { flex: 1; }
  .modal-cat-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.5px;
    margin-bottom: 10px;
    color: white;
  }
  .modal-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    font-weight: 900;
    color: var(--primary);
    line-height: 1.2;
    margin-bottom: 12px;
  }
  .modal-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .modal-meta-chip {
    display: flex;
    align-items: center;
    gap: 6px;
    background: #1a2840;
    border-radius: 20px;
    padding: 5px 14px;
    font-size: 0.78rem;
    color: var(--primary-mid);
    font-weight: 600;
  }
  .modal-meta-chip .label {
    opacity: 0.65;
    font-weight: 400;
    margin-right: 2px;
  }
  .modal-close {
    background: none;
    border: none;
    font-size: 26px;
    cursor: pointer;
    color: var(--text-light);
    padding: 4px 8px;
    border-radius: 8px;
    transition: all 0.2s;
    line-height: 1;
    flex-shrink: 0;
  }
  .modal-close:hover { background: #1a2840; color: var(--text); }

  .modal-body {
    overflow-y: auto;
    padding: 24px 28px;
    flex: 1;
  }
  .modal-body::-webkit-scrollbar { width: 6px; }
  .modal-body::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

  .modal-tabs {
    display: flex;
    gap: 0;
    border-bottom: 2px solid var(--border);
    margin-bottom: 24px;
    overflow-x: auto;
  }
  .modal-tab {
    padding: 10px 18px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-light);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    white-space: nowrap;
    transition: all 0.2s;
    font-family: inherit;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
  }
  .modal-tab:hover { color: var(--primary); }
  .modal-tab.active { color: var(--accent); border-bottom-color: var(--accent); }

  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  .info-section {
    margin-bottom: 24px;
  }
  .info-section-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-light);
    margin-bottom: 10px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .info-section-title .icon {
    width: 26px; height: 26px;
    background: var(--primary);
    color: white;
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px;
  }
  .info-content {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--text);
    white-space: pre-line;
  }
  .info-content.highlight {
    background: linear-gradient(135deg, #1a2840, #1e3050);
    border-left: 4px solid var(--primary);
    padding: 14px 18px;
    border-radius: 0 10px 10px 0;
  }

  .func-list { list-style: none; }
  .func-list li {
    padding: 10px 0 10px 28px;
    border-bottom: 1px solid #f0f0f0;
    font-size: 0.88rem;
    line-height: 1.6;
    position: relative;
  }
  .func-list li:last-child { border-bottom: none; }
  .func-list li::before {
    content: attr(data-n);
    position: absolute;
    left: 0;
    top: 10px;
    width: 20px; height: 20px;
    background: var(--accent);
    color: white;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
  }

  .req-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .req-card {
    background: #0d1828;
    border-radius: 12px;
    padding: 14px;
    border: 1px solid var(--border);
  }
  .req-card h4 {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-light);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .req-card ul { list-style: none; }
  .req-card ul li {
    padding: 5px 0 5px 16px;
    font-size: 0.82rem;
    line-height: 1.5;
    position: relative;
    border-bottom: 1px dashed var(--border);
  }
  .req-card ul li:last-child { border-bottom: none; }
  .req-card ul li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--success);
    font-weight: 700;
    font-size: 0.75rem;
  }

  .rel-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .rel-box {
    background: #0d1e30;
    border-radius: 12px;
    padding: 14px;
    border: 1px solid #1a3050;
  }
  .rel-box.ext { background: #0d1e18; border-color: #1a3028; }
  .rel-box h4 {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--primary-mid);
    margin-bottom: 8px;
  }
  .rel-box.ext h4 { color: var(--success); }
  .rel-box p { font-size: 0.82rem; line-height: 1.7; white-space: pre-line; }

  .alert-box {
    background: linear-gradient(135deg, #1e1a08, #261f0a);
    border: 1px solid #4a3a10;
    border-left: 4px solid var(--accent);
    border-radius: 0 10px 10px 0;
    padding: 14px 18px;
    font-size: 0.85rem;
    line-height: 1.7;
    color: #d4c070;
  }
  .alert-box strong { color: #f0d880; }

  /* ─── INFO BAR ─── */
  .info-bar {
    background: var(--primary);
    color: white;
    padding: 12px 32px;
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 0.8rem;
    flex-wrap: wrap;
  }
  .info-bar-item { display: flex; align-items: center; gap: 6px; opacity: 0.8; }
  .info-bar-item strong { opacity: 1; color: var(--accent-light); }

  /* ─── EMPTY STATE ─── */
  .empty-state {
    text-align: center;
    padding: 60px 20px;
    color: var(--text-light);
  }
  .empty-state .emoji { font-size: 3rem; margin-bottom: 16px; }
  .empty-state h3 { font-size: 1.1rem; margin-bottom: 8px; }

  
.organigrama {
  background: var(--white);
  padding: 20px;
  margin: 20px;
  border-radius: 16px;
  box-shadow: var(--card-shadow);
  text-align: center;
  border: 1px solid var(--border);
}

.org-box {
  background: linear-gradient(145deg,#0a2f6b,#123e8c);
  color: white;
  padding: 12px 20px;
  margin: 10px;
  border-radius: 10px;
  display: inline-block;
  font-weight: 600;
}

.org-row {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
}


/* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .sidebar { display: none; }
    .req-grid, .rel-grid { grid-template-columns: 1fr; }
    .cards-area { padding: 16px; }
    .modal-body { padding: 16px; }
    .modal-header { padding: 16px; }
    .topbar-inner { flex-wrap: wrap; }
    .topbar-search { min-width: 200px; }
  }

  @media (max-width: 600px) {
    .cards-grid { grid-template-columns: 1fr; }
    .topbar-badge { display: none; }
  }
</style>
</head>
<body>

<div id="loginScreen" style="
position:fixed;
inset:0;
background:linear-gradient(135deg,#050e1e,#0a1830);
display:flex;
align-items:center;
justify-content:center;
z-index:9999;
">

  <div style="
  background:#161f30;
  padding:40px;
  border-radius:20px;
  box-shadow:0 20px 60px rgba(0,0,0,0.6);
  text-align:center;
  width:320px;
  border:1px solid #243050;
  ">

    <h2 style="color:#5a9ae0;margin-bottom:10px;">
    Acceso MOF 2026-2031
    </h2>

    <p style="color:#7a93b8;margin-bottom:20px;">
    Sistema Interno
    </p>

    <input id="user" placeholder="Usuario"
    style="width:100%;padding:10px;margin-bottom:10px;border-radius:8px;border:1px solid #243050;background:#0e1420;color:#dce6f5;">

    <input id="pass" type="password" placeholder="Contraseña"
    style="width:100%;padding:10px;margin-bottom:15px;border-radius:8px;border:1px solid #243050;background:#0e1420;color:#dce6f5;">

    <button onclick="login()" style="
    width:100%;
    padding:12px;
    background:#f0b429;
    border:none;
    color:#0e1420;
    font-weight:bold;
    border-radius:10px;
    cursor:pointer;
    font-size:1rem;
    ">
    Ingresar
    </button>

    <p id="error" style="color:#e05a5a;margin-top:10px;display:none;">
    Usuario o contraseña incorrectos
    </p>

  </div>
</div>


<!-- TOPBAR -->
<div class="topbar">
  <div class="topbar-inner">
    <div class="topbar-logo">🏛️</div>
    <div class="topbar-titles">
      <h1>MOF 2026-2031 Gestión Rosmery Ardaya Alcalde</h1>
      <p>Gobierno Autónomo Municipal de Huanuni · Oruro, Bolivia</p>
    </div>
    <div class="topbar-badge">App Departamento de Sistemas · Ing. I. P. M. G.</div>
    <button onclick="logout()" style="margin-right:10px;background:#f0b429;border:none;color:#0e1420;padding:6px 12px;border-radius:8px;cursor:pointer;font-weight:bold;">Salir</button>
    <div class="topbar-search">
      <span>🔍</span>
      <input type="text" id="searchInput" placeholder="Buscar cargo, área, función...">
    </div>
  </div>
</div>

<!-- INFO BAR -->
<div class="info-bar">
